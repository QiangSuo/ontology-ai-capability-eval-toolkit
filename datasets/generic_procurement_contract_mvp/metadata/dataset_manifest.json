  "design_notes": {
    "input_only": true,
    "fictional_data_statement": "All entities, people, suppliers, transaction numbers, emails, amounts and dates are fictional and created for testing.",
    "intentional_variations": [
      "Supplier is the preferred business term, while some code methods use Vendor.",
      "Purchase Request is often abbreviated as PR in code and data.",
      "Goods Receipt is also called GRN in warehouse documents and sample receipt numbers.",
      "Payment Request is also called Payment Application in documents and code method names.",
      "Approval threshold wording differs slightly between DDL/business rules and code.",
      "Invoice matching tolerance differs between policy text and code constant.",
      "Contract activation policy mentions both-party signature, while DDL stores legal approval and activation timestamps only."
    ]
  }
