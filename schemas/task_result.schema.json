{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/task_result.schema.json",
  "title": "Task Result Schema",
  "description": "单个评估任务的执行结果，用于记录输入、输出、证据、校验状态和人工介入。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "task_name",
    "mode",
    "status",
    "started_at",
    "output_artifacts"
  ],
  "properties": {
    "task_id": {
      "$ref": "#/$defs/identifier"
    },
    "task_name": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "fixed_prompt",
        "free_form"
      ]
    },
    "level": {
      "type": "string",
      "enum": [
        "smoke",
        "standard",
        "deep_agentic",
        "custom"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "not_started",
        "running",
        "completed",
        "failed",
        "blocked",
        "skipped"
      ]
    },
    "tool_profile_ref": {
      "$ref": "#/$defs/identifier"
    },
    "customer_profile_ref": {
      "$ref": "#/$defs/identifier"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "duration_minutes": {
      "type": "number",
      "minimum": 0
    },
    "operator": {
      "$ref": "#/$defs/operator"
    },
    "input_artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      },
      "default": []
    },
    "output_artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      },
      "minItems": 1
    },
    "evidence_refs": {
      "$ref": "#/$defs/evidence_refs"
    },
    "schema_validation": {
      "$ref": "#/$defs/schema_validation"
    },
    "human_interventions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/human_intervention"
      },
      "default": []
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "执行中遇到的限制。"
    },
    "metrics": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "number",
          "integer",
          "string",
          "boolean"
        ]
      }
    },
    "notes": {
      "type": "string"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9_.:-]+$",
      "description": "稳定标识符，建议使用英文、数字、下划线、短横线、点号或冒号。"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "置信度，0 表示完全不确定，1 表示高度确定。"
    },
    "evidence_refs": {
      "type": "array",
      "description": "关联的 evidence_id 列表。",
      "items": {
        "$ref": "#/$defs/identifier"
      },
      "uniqueItems": true,
      "default": []
    },
    "provenance": {
      "type": "object",
      "description": "产出来源、生成方式和可追溯信息。",
      "additionalProperties": false,
      "properties": {
        "created_by": {
          "type": "string",
          "description": "创建人、操作员或工具。"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "创建时间。"
        },
        "method": {
          "type": "string",
          "enum": [
            "manual",
            "ai_generated",
            "hybrid",
            "imported"
          ],
          "description": "生成方式。"
        },
        "source_system": {
          "type": "string",
          "description": "来源系统或数据集。"
        },
        "tool_profile_ref": {
          "$ref": "#/$defs/identifier"
        },
        "prompt_ref": {
          "type": "string",
          "description": "使用的提示词或提示词版本。"
        },
        "version": {
          "type": "string",
          "description": "产物版本。"
        },
        "notes": {
          "type": "string",
          "description": "补充说明。"
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "artifact_type",
        "path"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/identifier"
        },
        "artifact_type": {
          "type": "string",
          "enum": [
            "ontology",
            "evidence",
            "report",
            "log",
            "prompt",
            "raw_output",
            "other"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "schema_ref": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "operator": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "operator_id": {
          "$ref": "#/$defs/identifier"
        },
        "experience_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "expert"
          ]
        },
        "role": {
          "type": "string"
        }
      }
    },
    "schema_validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "is_valid"
      ],
      "properties": {
        "is_valid": {
          "type": "boolean"
        },
        "schema_name": {
          "type": "string"
        },
        "validator": {
          "type": "string"
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "human_intervention": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intervention_type",
        "description"
      ],
      "properties": {
        "intervention_type": {
          "type": "string",
          "enum": [
            "prompt_rewrite",
            "manual_fix",
            "retry",
            "file_selection",
            "clarification",
            "other"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "operator_id": {
          "$ref": "#/$defs/identifier"
        }
      }
    }
  }
}
